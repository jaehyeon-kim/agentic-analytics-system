# =============================================================================
# Amazon Bedrock (default)
# =============================================================================
# Used when running: python orchestrator.py (no flags)
# Authenticates via AWS credentials (aws configure / IAM role / env vars).
BEDROCK_MODEL_ID=""
AWS_PROFILE=""
AWS_REGION=""

# =============================================================================
# LiteLLM API Keys (optional)
# =============================================================================
# Used when running: python orchestrator.py --use-api-key
# Only the key for your active model is required.
# Model examples: gemini/gemini-3.1-flash-lite, claude-3-5-sonnet-20240620, gpt-4o, ollama/qwen2.5-coder:7b
AGENT_MODEL=""
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
