# Choose your active model
# Options: claude-3-5-sonnet-20240620, gemini/gemini-1.5-pro-latest, gpt-4o, ollama/qwen2.5-coder:7b
AGENT_MODEL="your-agent-model"

# Supply the keys (only the one for your active model is required)
GEMINI_API_KEY="your-gemini-key"
ANTHROPIC_API_KEY="your-claude-key"
OPENAI_API_KEY="your-openai-key"

# WREN settings
WREN_HOME="../semantic_engine/.wren_project"
